        <name>Validate Phone Number</name>
        <order/>
        <script><![CDATA[function onSubmit() {

    var phone = g_form.getValue('phone_number');

    var phoneRegex = /^\d{10}$/;

    if (!phoneRegex.test(phone)) {

        g_form.addErrorMessage(
            'Phone Number must contain exactly 10 digits.'
        );

        return false;
    }

    return true;
}]]></script>
